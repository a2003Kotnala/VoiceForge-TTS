!backend/storage/audio/.gitkeep

# Python service
kokoro-service/.venv/
kokoro-service/__pycache__/
kokoro-service/.pytest_cache/
kokoro-service/.mypy_cache/
kokoro-service/.ruff_cache/
kokoro-service/.coverage
kokoro-service/htmlcov/
