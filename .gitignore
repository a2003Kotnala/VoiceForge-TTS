# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env.local
kokoro-service/.env

# Logs and OS files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db

# Editor and tooling caches
.vercel/
.turbo/
.cache/
.pytest_cache/
